{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@babel/preset-env": "^7.14.1",
    "@babel/preset-react": "^7.13.13",
    "@babel/preset-typescript": "^7.13.0",
    "@material-ui/core": "^4.11.4",
    "@material-ui/icons": "^4.11.2",
    "@material-ui/lab": "^4.0.0-alpha.58",
    "@material-ui/styles": "^4.11.4",
    "@types/lodash-es": "^4.17.4",
    "@types/node": "^15.0.2",
    "@types/react": "^17.0.5",
    "@types/react-dom": "^17.0.4",
    "@types/react-relay": "^11.0.1",
    "@types/react-router-dom": "^5.1.7",
    "@types/react-router-hash-link": "^2.0.0",
    "@types/relay-runtime": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^4.23.0",
    "@typescript-eslint/parser": "^4.23.0",
    "@wasm-tool/wasm-pack-plugin": "^1.4.0",
    "ace-builds": "^1.4.12",
    "babel-loader": "^8.2.2",
    "babel-plugin-relay": "^11.0.2",
    "clsx": "^1.1.1",
    "css-loader": "^5.2.4",
    "eslint-config-prettier": "^8.3.0",
    "eslint-config-react": "^1.1.7",
    "eslint-plugin-jest": "^24.3.6",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-react": "^7.23.2",
    "eslint-plugin-react-hooks": "^4.2.0",
    "fork-ts-checker-webpack-plugin": "^6.2.7",
    "gdlk_wasm": "file:../crates/wasm/pkg",
    "graphql": "^15.5.0",
    "graphql-schema-linter": "^2.0.1",
    "html-webpack-plugin": "^5.3.1",
    "http-proxy-middleware": "^2.0.0",
    "lodash-es": "^4.17.21",
    "nodemon": "^2.0.7",
    "prettier": "^2.3.0",
    "query-string": "^7.0.0",
    "react": "^17.0.2",
    "react-ace": "^8.1.0",
    "react-dom": "^17.0.2",
    "react-relay": "^11.0.2",
    "react-router-dom": "^5.2.0",
    "relay-compiler": "^11.0.2",
    "relay-compiler-language-typescript": "^14.0.0",
    "relay-config": "^11.0.2",
    "relay-hooks": "^4.2.0",
    "source-map-explorer": "^2.5.2",
    "source-map-loader": "^2.0.1",
    "style-loader": "^2.0.0",
    "ts-loader": "^9.1.2",
    "typescript": "^4.2.4",
    "wasm-loader": "^1.3.0",
    "webpack": "^5.37.0",
    "webpack-bundle-analyzer": "^4.4.1",
    "webpack-cli": "^4.7.0",
    "webpack-dev-server": "^3.11.2"
  },
  "scripts": {
    "analyze": "NODE_ENV=production mkdir -p analysis && source-map-explorer 'build/static/js/*.js' --html > analysis/index.html",
    "prebuild": "npm run relay",
    "build": "NODE_ENV=production webpack",
    "clean": "rm -rf node_modules **/__generated__",
    "lint": "eslint './**/*.{js,ts,tsx}'",
    "lint:fix": "npm run lint -- --fix",
    "lint:gql": "graphql-schema-linter",
    "relay": "relay-compiler",
    "relay:watch": "nodemon -x \"npm run relay\" -w src -e \"ts tsx\" -i \"**/__generated/*\"",
    "start": "webpack serve",
    "pretype-check": "npm run relay",
    "type-check": "tsc",
    "wasm-pack": "cd ../crates/wasm; wasm-pack build"
  },
  "graphql-schema-linter": {
    "schemaPaths": [
      "../crates/api/schema.graphql"
    ]
  }
}
